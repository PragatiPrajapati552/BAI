<% layout('layout/boilerplate.ejs') -%>

<div class="container d-flex justify-content-center align-items-center mt-5 mb-5">
    <div class="row w-100">
        <div class="col-md-8 offset-md-2 text-center">
            <div class="alert alert-danger" role="alert">
                <h2 class="alert-heading display-4 fw-bold mb-3"><%= err.statusCode || 500 %> Error</h2>
                <h4 class="mb-4 text-muted"><%= err.message || "Something went wrong!" %></h4>
                <hr>
                <p class="mb-4">
                    We're sorry, but an unexpected error has occurred. Please try again or return to the homepage.
                </p>
                <a href="/" class="btn btn-danger btn-lg px-4 rounded-pill">Back to Home</a>
            </div>
            <% if (process.env.NODE_ENV !== 'production' && err.stack) { %>
                <div class="text-start mt-4">
                    <button class="btn btn-outline-secondary mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#stackTrace" aria-expanded="false" aria-controls="stackTrace">
                        Show Stack Trace
                    </button>
                    <div class="collapse" id="stackTrace">
                        <div class="card card-body bg-light text-dark text-start" style="font-family: monospace; font-size: 0.85rem; overflow-x: auto;">
                            <%= err.stack %>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>
